<Window x:Class="WpfApp.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обувной магазин - Заказы" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        FontFamily="Times New Roman">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" BorderBrush="#FFFFFF" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="Информация по заказам" 
                           FontSize="18" FontWeight="Bold" 
                           VerticalAlignment="Center" Foreground="#000000"
                           FontFamily="Times New Roman"/>
                <Button x:Name="BackButton" Content="Назад" Width="100" Height="32"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#FFFFFF" Foreground="#000000"
                        BorderBrush="#FFFFFF" BorderThickness="1"
                        Cursor="Hand" Click="BackButton_Click"
                        FontFamily="Times New Roman" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Список заказов в виде карточек -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="OrdersListBox" 
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="OrdersListBox_MouseDoubleClick">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Карточка заказа -->
                        <Border BorderBrush="#FFFFFF" BorderThickness="1" 
                                Margin="0,0,0,12" Padding="15,12"
                                HorizontalAlignment="Stretch">

                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Левая часть -->
                                <Border Grid.Column="0" 
                                        BorderBrush="#FFFFFF" 
                                        BorderThickness="1"
                                        Padding="15,12"
                                        Margin="0,0,15,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Артикул заказа -->
                                        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" 
                                                Padding="10,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Артикул заказа:" 
                                                           FontWeight="Bold" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Id}" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Статус заказа -->
                                        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" 
                                                Padding="10,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Статус заказа:" 
                                                           FontWeight="Bold" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Адрес пункта выдачи -->
                                        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" 
                                                Padding="10,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Адрес пункта выдачи:" 
                                                           FontWeight="Bold" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PickupPoint.Address}" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Дата заказа -->
                                        <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" 
                                                Padding="10,8" Margin="0,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Дата заказа:" 
                                                           FontWeight="Bold" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1" Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                                           Foreground="#000000"
                                                           FontFamily="Times New Roman"
                                                           FontSize="13"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Правая часть -->
                                <Border Grid.Column="1" 
                                        BorderBrush="#CCCCCC" 
                                        BorderThickness="1"
                                        VerticalAlignment="Stretch"
                                        Margin="5,0,0,0">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Дата" 
                                                   FontWeight="Bold" 
                                                   FontSize="14"
                                                   Foreground="#000000"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Times New Roman"/>
                                        <TextBlock Text="доставки" 
                                                   FontWeight="Bold" 
                                                   FontSize="14"
                                                   Foreground="#000000"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,15"
                                                   FontFamily="Times New Roman"/>
                                        <TextBlock Text="{Binding DeliveryDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                                   FontSize="16" 
                                                   FontWeight="Bold"
                                                   Foreground="#000000"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Times New Roman"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Стиль для выделения карточки -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="#00FA9A"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="-2,0,-2,10"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,15,0,0" Padding="10,10,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="AddOrderButton" Content="Добавить заказ" Width="140" Height="34" 
                            Margin="0,0,10,0" Background="#00FA9A" Foreground="#000000"
                            BorderBrush="#000000" BorderThickness="1"
                            Cursor="Hand" Click="AddOrderButton_Click" 
                            FontFamily="Times New Roman" FontSize="13"/>
                    <Button x:Name="DeleteOrderButton" Content="Удалить заказ" Width="140" Height="34" 
                            Background="#FFFFFF" Foreground="#000000" 
                            BorderBrush="#000000" BorderThickness="1"
                            Cursor="Hand" Click="DeleteOrderButton_Click"
                            FontFamily="Times New Roman" FontSize="13"/>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock" Text="Готово" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#000000" FontFamily="Times New Roman" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>