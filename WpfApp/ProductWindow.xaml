<Window x:Class="WpfApp.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="650" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Times New Roman"
        Closing="Window_Closing">
    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Информация о товаре" FontSize="20" FontWeight="Bold" 
                       Margin="0,0,0,15" Foreground="#333333" FontFamily="Times New Roman"/>

            <!-- Фото -->
            <TextBlock Grid.Row="1" Text="Фото товара:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <Border Grid.Row="2" Width="200" Height="133" BorderBrush="#CCCCCC" BorderThickness="1" 
                    HorizontalAlignment="Left" Margin="0,0,0,10" Background="#F5F5F5">
                <Image x:Name="ProductImage" Stretch="Uniform"/>
            </Border>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PhotoPathTextBox" Height="28" Margin="0,0,5,10" 
                         FontFamily="Times New Roman"/>
                <Button Grid.Column="1" Content="Загрузить" Width="90" Height="28" Margin="0,0,5,10" 
                        Background="#00FA9A" Foreground="#333333" BorderThickness="1"
                        Cursor="Hand" Click="BrowsePhotoButton_Click" FontFamily="Times New Roman"/>
                <Button Grid.Column="2" Content="Удалить" Width="70" Height="28" Margin="0,0,0,10" 
                        Background="#FF6347" Foreground="White" BorderThickness="1"
                        Cursor="Hand" Click="DeletePhotoButton_Click" FontFamily="Times New Roman"/>
            </Grid>

            <!-- Артикул -->
            <TextBlock Grid.Row="4" Text="Артикул:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="5" x:Name="ArticleTextBox" Height="28" Margin="0,0,0,10" 
                     FontFamily="Times New Roman"/>

            <!-- Название -->
            <TextBlock Grid.Row="6" Text="Название:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="7" x:Name="NameTextBox" Height="28" Margin="0,0,0,10" 
                     FontFamily="Times New Roman"/>

            <!-- Категория -->
            <TextBlock Grid.Row="8" Text="Категория:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <ComboBox Grid.Row="9" x:Name="CategoryComboBox" Height="28" Margin="0,0,0,10" 
                      DisplayMemberPath="Name" FontFamily="Times New Roman"/>

            <!-- Производитель -->
            <TextBlock Grid.Row="10" Text="Производитель:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <ComboBox Grid.Row="11" x:Name="ManufacturerComboBox" Height="28" Margin="0,0,0,10" 
                      DisplayMemberPath="Name" FontFamily="Times New Roman"/>

            <!-- Поставщик -->
            <TextBlock Grid.Row="12" Text="Поставщик:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <ComboBox Grid.Row="13" x:Name="SupplierComboBox" Height="28" Margin="0,0,0,10" 
                      DisplayMemberPath="Name" FontFamily="Times New Roman"/>

            <!-- Цена -->
            <TextBlock Grid.Row="14" Text="Цена (руб.):" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="15" x:Name="PriceTextBox" Height="28" Margin="0,0,0,10" 
                     FontFamily="Times New Roman"/>

            <!-- Ед. изм. -->
            <TextBlock Grid.Row="16" Text="Единица измерения:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="17" x:Name="UnitTextBox" Height="28" Margin="0,0,0,10" Text="шт." 
                     FontFamily="Times New Roman"/>

            <!-- Остаток -->
            <TextBlock Grid.Row="18" Text="Остаток на складе:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="19" x:Name="StockQuantityTextBox" Height="28" Margin="0,0,0,10" 
                     FontFamily="Times New Roman"/>

            <!-- Скидка -->
            <TextBlock Grid.Row="20" Text="Скидка активный (%):" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="21" x:Name="DiscountTextBox" Height="28" Margin="0,0,0,10" 
                     FontFamily="Times New Roman"/>

            <!-- Описание -->
            <TextBlock Grid.Row="22" Text="Описание:" Margin="0,5,0,2" FontFamily="Times New Roman"/>
            <TextBox Grid.Row="23" x:Name="DescriptionTextBox" Height="70" Margin="0,0,0,10" 
                     TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Times New Roman"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="24" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="CancelButton" Content="Отмена" Width="110" Height="32" 
                        Margin="0,0,10,0" Background="#E0E0E0" Foreground="#333333" 
                        BorderThickness="1" Cursor="Hand" Click="CancelButton_Click"
                        FontFamily="Times New Roman"/>
                <Button x:Name="SaveButton" Content="Сохранить" Width="110" Height="32" 
                        Background="#00FA9A" Foreground="#333333" BorderThickness="1" 
                        Cursor="Hand" Click="SaveButton_Click" FontFamily="Times New Roman"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
