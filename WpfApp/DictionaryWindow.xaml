<Window x:Class="WpfApp.DictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочники" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Times New Roman">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление справочниками" FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,10" Foreground="#333333" FontFamily="Times New Roman"/>

        <!-- Переключатель справочников -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="CategoriesRadio" Content="Категории" GroupName="DictType"
                         Margin="0,0,15,0" Checked="DictType_Changed" FontFamily="Times New Roman"/>
            <RadioButton x:Name="ManufacturersRadio" Content="Производители" GroupName="DictType"
                         Margin="0,0,15,0" Checked="DictType_Changed" FontFamily="Times New Roman"/>
            <RadioButton x:Name="SuppliersRadio" Content="Поставщики" GroupName="DictType"
                         Margin="0,0,15,0" Checked="DictType_Changed" FontFamily="Times New Roman"/>
            <RadioButton x:Name="PickupPointsRadio" Content="Пункты выдачи" GroupName="DictType"
                         Margin="0,0,15,0" Checked="DictType_Changed" FontFamily="Times New Roman"/>
        </StackPanel>

        <!-- Таблица данных -->
        <Border Grid.Row="2" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="DictDataGrid" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single"
                      AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                      FontFamily="Times New Roman" FontSize="13"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddButton" Content="Добавить" Width="120" Height="32"
                    Margin="0,0,10,0" Background="#00FA9A" Foreground="#333333"
                    BorderThickness="1" Cursor="Hand" Click="AddButton_Click"
                    FontFamily="Times New Roman"/>
            <Button x:Name="EditButton" Content="Редактировать" Width="120" Height="32"
                    Margin="0,0,10,0" Background="#87CEEB" Foreground="#333333"
                    BorderThickness="1" Cursor="Hand" Click="EditButton_Click"
                    FontFamily="Times New Roman"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="120" Height="32"
                    Margin="0,0,10,0" Background="#FF6347" Foreground="White"
                    BorderThickness="1" Cursor="Hand" Click="DeleteButton_Click"
                    FontFamily="Times New Roman"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="100" Height="32"
                    Background="#E0E0E0" Foreground="#333333" BorderThickness="1"
                    Cursor="Hand" Click="CloseButton_Click"
                    FontFamily="Times New Roman"/>
        </StackPanel>
    </Grid>
</Window>
